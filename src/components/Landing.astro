---
import { SITE_TITLE } from "@/consts";
---

<div class="pt-2">
  <!-- HERO CONTENT -->
  <div class="flex flex-col items-center w-full px-4 flex-1 justify-center text-center gap-6">
    <h1 class="text-3xl md:text-4xl font-semibold tracking-tight text-[#2d3436]">
      pbrain studios
    </h1>
    <p class="max-w-3xl text-base md:text-lg text-zinc-600">
      Independent developer building AI-driven games and creative applications.
      Portfolio of engineering, research, and interactive projects.
    </p>

    <!-- QUICK HIGHLIGHTS -->
    <div class="flex flex-wrap items-center justify-center gap-4 text-sm text-zinc-600">
      <span class="px-3 py-1 rounded-full border border-zinc-300">Python • FastAPI • Next.js • Supabase</span>
      <span class="px-3 py-1 rounded-full border border-zinc-300">AI dialogue systems • RAG • State machines</span>
      <span class="px-3 py-1 rounded-full border border-zinc-300">San Francisco, CA</span>
    </div>

    <!-- Primary CTAs -->
    <div class="flex flex-col sm:flex-row gap-3 mt-2">
      <a
        href="/projects"
        class="px-5 py-3 rounded-xl bg-[#2d3436] text-white font-medium hover:opacity-90 transition"
        aria-label="View projects by pbrain studios"
      >
        View Projects
      </a>
      <a
        href="/about"
        class="px-5 py-3 rounded-xl border border-zinc-300 text-zinc-800 font-medium hover:border-zinc-500 transition"
        aria-label="Learn more about pbrain studios"
      >
        About the Studio
      </a>
    </div>
  </div>

  <!-- FEATURED PROJECT: FOIL ENGINE -->
  <div class="w-full max-w-5xl mx-auto mt-10 px-4">
    <div class="rounded-2xl border border-zinc-300 overflow-hidden">
      <div class="grid md:grid-cols-2">
        <div class="p-5 md:p-7 flex flex-col gap-4">
          <h2 class="text-xl md:text-2xl font-semibold text-zinc-800">Featured: Foil Engine</h2>
          <p class="text-zinc-600 text-sm md:text-base">
            An AI-powered platform for building interactive NPCs without scripted dialogue trees.
            Define character personas and conversation flows as state machines. The AI handles
            natural language while staying in character.
          </p>
          <ul class="text-zinc-600 text-sm space-y-1">
            <li>• Tech: Next.js 15, FastAPI, PostgreSQL, LiteLLM, Supabase</li>
            <li>• Systems: State machine conversations, RAG knowledge, vendor-agnostic multi-model pipeline</li>
            <li>• SDKs: Python, TypeScript, Unity</li>
          </ul>
          <div class="flex gap-3 pt-1">
            <a href="https://foilengine.io" target="_blank" rel="noopener"
               class="px-4 py-2 rounded-lg bg-[#2d3436] text-white font-medium hover:opacity-90 transition">Try the Editor</a>
            <a href="/projects/foil-engine"
               class="px-4 py-2 rounded-lg border border-zinc-400 text-sm font-medium text-zinc-800 hover:border-zinc-600 transition">View Details</a>
          </div>
        </div>
        <div class="relative aspect-video md:aspect-auto md:h-full bg-zinc-100">
          <img src="/foil-engine.png" alt="Foil Engine: AI-powered NPC conversation platform"
               class="w-full h-full object-cover" loading="eager" />
        </div>
      </div>
    </div>
  </div>

  <!-- STATS STRIP -->
  <div class="w-full bg-zinc-50 border-y border-zinc-200 mt-10">
    <div class="max-w-5xl mx-auto px-4 py-6 grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
      <div>
        <div class="text-2xl font-semibold text-zinc-800">2</div>
        <div class="text-sm text-zinc-600">Production platforms</div>
      </div>
      <div>
        <div class="text-2xl font-semibold text-zinc-800">3 SDKs</div>
        <div class="text-sm text-zinc-600">Python, TypeScript, Unity</div>
      </div>
      <div>
        <div class="text-2xl font-semibold text-zinc-800">Full-stack</div>
        <div class="text-sm text-zinc-600">Frontend, backend, infra</div>
      </div>
    </div>
  </div>

  <!-- SELECTED PROJECTS -->
  <div class="w-full max-w-5xl mx-auto mt-10 px-4 pb-10">
    <h3 class="text-xl md:text-2xl font-semibold text-zinc-800 mb-6">Selected Projects</h3>
    <div class="grid md:grid-cols-3 gap-6">

      <!-- Sexy Unique RPG -->
      <a href="/projects" class="rounded-xl border border-zinc-300 p-5 flex flex-col gap-2 hover:border-zinc-500 transition">
        <h4 class="text-lg font-semibold text-zinc-800">Sexy Unique RPG</h4>
        <p class="text-zinc-600 text-sm">
          A 16-bit narrative RPG with AI-driven characters, built on an early version of the Foil Engine dialogue system. Unity + Python/FastAPI.
        </p>
      </a>

      <!-- Recipe Generator -->
      <a href="/projects" class="rounded-xl border border-zinc-300 p-5 flex flex-col gap-2 hover:border-zinc-500 transition">
        <h4 class="text-lg font-semibold text-zinc-800">Recipe Generator & Voice Synth</h4>
        <p class="text-zinc-600 text-sm">
          A Nara Smith-style recipe generator paired with a custom voice synthesizer. FastAPI + Coqui TTS.
        </p>
      </a>

      <!-- AI Asset Marketplace -->
      <a href="/projects" class="rounded-xl border border-zinc-300 p-5 flex flex-col gap-2 hover:border-zinc-500 transition">
        <h4 class="text-lg font-semibold text-zinc-800">AI Asset Marketplace</h4>
        <p class="text-zinc-600 text-sm">
          A marketplace where artists upload gaming assets to fine-tune AI models. Developers purchase generated assets in the artist's style.
        </p>
      </a>

    </div>
  </div>
</div>
