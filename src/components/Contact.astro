---
import { Image } from "astro:assets";
import { QUOTE, SITE_TITLE } from "@/consts";
---

<div
  class="fixed top-0 -z-10 !w-screen md:block h-screen bg-cover bg-center tracking-wide"
></div>

<section
  class="flex-1 w-full !z-[20] relative flex items-start justify-center pt-8 overflow-auto"
  id="hero"
>
  <div class="w-full max-w-3xl mx-auto px-6 md:px-10 flex flex-col gap-12 text-zinc-800 leading-relaxed">

    <!-- Heading -->
    <div class="text-center">
      <h1 class="text-3xl md:text-4xl font-semibold mb-3">Get in Touch</h1>
      <p class="text-base md:text-lg text-zinc-600">
        Whether you’re interested in collaborating, discussing opportunities, 
        or just learning more about my work, feel free to reach out.
      </p>
    </div>

    <!-- Contact Options -->
    <div class="flex flex-col items-center gap-6">
      <!-- Email -->
      <a
        href="mailto:paige@brain.gg"
        class="px-6 py-3 rounded-xl bg-black text-white font-medium hover:opacity-90 transition"
      >
        Email Me
      </a>

      <!-- Social Links -->
      <div class="flex gap-6 text-zinc-600 text-sm md:text-base">
        <a
          href="https://github.com/py1218"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-black transition"
        >
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/paige-y/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-black transition"
        >
          LinkedIn
        </a>
      </div>
    </div>

    <!-- Optional: Short Note -->
    <div class="text-center text-zinc-500 text-sm">
      <p>I try to respond within a few days. Thanks for your patience!</p>
    </div>

  </div>

</section>



